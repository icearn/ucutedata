# Local example values for KiwiSaver Insight.
# Keep the real .env out of git. These values are safe examples only.

DB_NAME=kiwisaver
DB_USER=kiwisaver_app
DB_PASSWORD=change_me_local_db_password
DB_HOST=localhost
# Container-to-container traffic uses 5432. Host-side access is exposed on 5433.
DB_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@kiwisaver.app
PGADMIN_DEFAULT_PASSWORD=change_me_local_pgadmin_password

TZ=Pacific/Auckland
CRON_SCHEDULE=15 18 * * 1-5

MESSAGE_HUB_TOPIC=message-hub.notifications.v1
MESSAGE_HUB_DEFAULT_CHANNELS=console

# Optional outbound channels
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMS_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
IM_WEBHOOK_URL=
MESSAGE_HUB_WEBHOOK_TARGETS_JSON={}
